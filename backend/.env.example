# ============================================================
# MemoryAgent · Qwen 环境变量模板
# 复制为 .env 后填入真实值：cp .env.example .env
# ============================================================

# ---- Qwen Cloud (OpenAI 兼容接口) ----
# 通过 https://bit.ly/qwencloud-getapi 申请黑客松专属 API Key（国际版 key，与国内百炼 key 不通用）
QWEN_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# DashScope OpenAI 兼容端点 (国际版，Qwen Cloud 黑客松官方指定；国内版 dashscope.aliyuncs.com 的 key 在此不可用)
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# 对话模型
QWEN_MODEL=qwen-max

# ---- 记忆存储路径 ----
# ChromaDB 向量库持久化目录
CHROMA_DIR=./chroma_db
# SQLite 用户画像数据库文件
SQLITE_PATH=./profiles.db

# ---- Embedding 模型 (多语言, 支持中文) ----
EMBED_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# ---- 遗忘机制 ----
# 时间衰减系数 lambda: 越大遗忘越快 (score = sim * exp(-lambda * days))
FORGETTING_LAMBDA=0.01

# ---- 检索 ----
# 每次召回的记忆条数
RETRIEVE_TOP_K=5

# ---- CORS (逗号分隔的前端来源) ----
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
