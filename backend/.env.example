# ============================================================
# MemoryAgent · Qwen 环境变量模板
# 复制为 .env 后填入真实值：cp .env.example .env
# ============================================================

# ---- Qwen Cloud (OpenAI 兼容接口) ----
# 通过 https://bit.ly/qwencloud-getapi 申请黑客松专属 API Key（国际版 key，与国内百炼 key 不通用）
QWEN_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# DashScope OpenAI 兼容端点 (国际版，Qwen Cloud 黑客松官方指定；国内版 dashscope.aliyuncs.com 的 key 在此不可用)
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# 对话模型
QWEN_MODEL=qwen-max

# ---- 记忆存储路径 ----
# ChromaDB 向量库持久化目录
CHROMA_DIR=./chroma_db
# SQLite 用户画像数据库文件
SQLITE_PATH=./profiles.db

# ---- Embedding 模型 (多语言, 支持中文) ----
EMBED_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# ---- 遗忘机制 ----
# 时间衰减系数 lambda: 越大遗忘越快 (score = sim * importance^alpha * exp(-lambda * days))
FORGETTING_LAMBDA=0.01
# 记忆强度衰减到此分数以下视为"已遗忘"，定期真删除（而非仅在检索时降权）
FORGETTING_PRUNE_THRESHOLD=0.05

# ---- 去重 ----
# 新记忆与已有记忆余弦相似度超过此值，视为同一事实的再次印证，强化旧记忆而非重复入库
DEDUP_SIMILARITY_THRESHOLD=0.92

# ---- 检索 / 上下文预算 ----
# 向量库候选池大小：先召回这么多条做遗忘重排，再由 token 预算精选实际注入的条数
MEMORY_CANDIDATE_POOL=20
# 注入 system prompt 的长期记忆文本 token 预算
MEMORY_TOKEN_BUDGET=800
# 注入 system prompt 的短期对话历史 token 预算
HISTORY_TOKEN_BUDGET=1500

# ---- CORS (逗号分隔的前端来源) ----
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
